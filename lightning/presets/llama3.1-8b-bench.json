{
    "_description": "Llama-3.1-8B benchmark preset — fp8-cs, seq=8192, single-node throughput measurement",
    "_parallelism": "FSDP=8 (all GPUs on 1 node)",
    "_effective_batch": "GBS = mbs(1) × fsdp(8) × ga(16) = 128 sequences per step",

    "model_name": "meta-llama/Llama-3.1-8B",

    "dataset": "/fsx/data/pretrain/wikitext-2",
    "local_dataset": true,

    "precision": "fp8-cs",
    "batch_size": 1,
    "gradient_accumulation_steps": 16,
    "max_length": 8192,
    "learning_rate": 3e-5,
    "max_steps": 100,

    "save_every_n_steps": 100,
    "val_check_interval": 100,
    "checkpoint_dir": "./checkpoints/llama3.1-8b-bench"
}
